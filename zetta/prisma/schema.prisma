generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String?
  email     String    @unique
  password  String
  role      Role      @default(CLIENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  addresses Address[]
  cartItems CartItem[]

  @@map("users")
}

model Address {
  id         String  @id @default(uuid())
  street     String
  city       String
  state      String
  number     String
  complement String?
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "addresses_userId_fkey")
  @@map("addresses")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String?     @db.Text
  image       String      @db.LongText
  price       Float
  stock       Int         @default(0)
  isAvailable Boolean     @default(true)
  orderItems  OrderItem[] // Relação com itens pedidos
  cartItems   CartItem[]  // Relação com itens do carrinho
  createdAt   DateTime    @default(now())
}

model Order {
  id        String      @id @default(uuid())
  total     Float
  status    String      @default("Finalizado")
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Preço unitário no momento da compra
}

// Tabela de Carrinho para persistência no DB
model CartItem {
  id        String  @id @default(uuid())
  productId String
  quantity  Int     @default(1)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId], map: "cartItems_userId_fkey")
}

enum Role {
  ADMIN
  CLIENT
}
